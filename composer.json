{
    "name": "jeffersongoncalves/jq-cli",
    "description": "A jq clone written in pure PHP on Laravel Zero. Lexer + parser + generator-based interpreter for the jq language. Windows-first, distributed as PHAR + .bat wrappers so jq finally works in CMD/PowerShell.",
    "keywords": ["cli", "jq", "json", "interpreter", "windows", "php"],
    "homepage": "https://github.com/jeffersongoncalves/jq-cli",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Jefferson Goncalves",
            "email": "jeffersongoncalves@users.noreply.github.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "jeffersongoncalves/laravel-zero-self-update": "^1.0",
        "laravel-zero/framework": "^12.0",
        "laravel/pint": "^1.25",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^3.8|^4.1"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "build": ["php jq app:build jq"],
        "lint": "./vendor/bin/pint",
        "test:lint": "./vendor/bin/pint --test",
        "test:unit": "./vendor/bin/pest --parallel",
        "test": [
            "@test:unit",
            "@test:lint"
        ]
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["builds/jq"]
}
